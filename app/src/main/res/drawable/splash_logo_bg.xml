<?xml version="1.0" encoding="utf-8"?>
<!--
    splash_logo_bg.xml
    The inner circle background for the logo icon.
    Deep navy with a bright blue border ring.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="80%p"
        android:startColor="#142244"
        android:endColor="#0A1628" />
    <stroke
        android:width="2dp"
        android:color="#3B82F6" />
</shape>
