<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_splash_logo.xml
    Traffic sign shield / AI recognition icon.
    Design: Octagonal stop-sign shape with an AI circuit dot pattern inside.
    Color: Blue gradient #3B82F6 → #1D4ED8
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="56dp"
    android:height="56dp"
    android:viewportWidth="56"
    android:viewportHeight="56">

    <!-- Outer octagon ring — blue -->
    <path
        android:fillColor="#3B82F6"
        android:pathData="
        M20,4 L36,4 L52,20 L52,36 L36,52 L20,52 L4,36 L4,20 Z" />

    <!-- Inner octagon — dark fill -->
    <path
        android:fillColor="#050D1A"
        android:pathData="
        M22,8 L34,8 L48,22 L48,34 L34,48 L22,48 L8,34 L8,22 Z" />

    <!-- Camera / lens circle — center white -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M28,18 A10,10 0 1,1 27.999,18 Z" />

    <!-- Inner lens iris — blue -->
    <path
        android:fillColor="#3B82F6"
        android:pathData="M28,21 A7,7 0 1,1 27.999,21 Z" />

    <!-- Pupil — white dot -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M28,25 A3,3 0 1,1 27.999,25 Z" />

    <!-- AI label bar — white rectangle below lens -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.9"
        android:pathData="M18,36 L38,36 L38,39 Q28,41 18,39 Z" />

    <!-- AI text dots (3 dots = AI indicator) -->
    <path
        android:fillColor="#3B82F6"
        android:pathData="M22,37.5 A1,1 0 1,1 21.999,37.5 Z" />
    <path
        android:fillColor="#3B82F6"
        android:pathData="M28,37.5 A1,1 0 1,1 27.999,37.5 Z" />
    <path
        android:fillColor="#3B82F6"
        android:pathData="M34,37.5 A1,1 0 1,1 33.999,37.5 Z" />

</vector>
