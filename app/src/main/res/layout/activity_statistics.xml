<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_statistics.xml
    Statistics screen — OLED dark theme consistent with dashboard.
    Sections:
      1. Header (back + title)
      2. Summary cards 2×2 grid
      3. Top signs list (RecyclerView)
      4. PieChart distribution
    States: loading overlay, empty state, error state
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dashboard_bg"
    android:fitsSystemWindows="true">

    <!-- ══════════════════ HEADER ══════════════════ -->
    <LinearLayout
        android:id="@+id/statsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/dashboard_surface_2"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_close"
            app:backgroundTint="@color/dashboard_surface"
            app:tint="@color/dashboard_text_primary"
            app:fabSize="mini"
            app:elevation="0dp"
            app:borderWidth="0dp"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thống Kê"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/dashboard_text_primary"
            android:layout_marginStart="12dp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_stats"
            android:tint="@color/dashboard_primary"
            android:contentDescription="Thống kê" />

    </LinearLayout>

    <!-- ══════════════════ SCROLLABLE CONTENT ══════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/statsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="32dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- ── Section label ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng quan"
                android:textSize="12sp"
                android:textColor="@color/dashboard_text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp" />

            <!-- ── Summary 2×2 Grid ── -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:layout_marginBottom="24dp">

                <!-- Card: Tổng lượt quét -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="@color/dashboard_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng lượt quét"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvStatTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Hôm nay -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="@color/dashboard_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hôm nay"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvStatToday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_success" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: 7 ngày qua -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="@color/dashboard_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7 ngày qua"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvStatWeek"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_amber" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Độ tin cậy TB -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="@color/dashboard_surface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Độ tin cậy TB"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvStatAvgConf"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_text_primary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- ── Section: Top biển báo ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Biển báo nhận diện nhiều nhất"
                android:textSize="12sp"
                android:textColor="@color/dashboard_text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/dashboard_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dashboard_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/llTopLabels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Section: Biểu đồ phân bổ ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phân bổ nhận diện"
                android:textSize="12sp"
                android:textColor="@color/dashboard_text_muted"
                android:textAllCaps="true"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/dashboard_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dashboard_border"
                app:strokeWidth="1dp">

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:padding="8dp" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══════════════════ EMPTY STATE ══════════════════ -->
    <LinearLayout
        android:id="@+id/emptyStateView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_stats"
            android:tint="@color/dashboard_text_muted"
            android:alpha="0.5"
            android:contentDescription="Trống" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa có dữ liệu quét"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/dashboard_text_secondary"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bắt đầu nhận diện biển báo&#10;để xem thống kê tại đây"
            android:textSize="14sp"
            android:textColor="@color/dashboard_text_muted"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>

    <!-- ══════════════════ LOADING OVERLAY ══════════════════ -->
    <FrameLayout
        android:id="@+id/loadingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC050D1A"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/dashboard_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang tải thống kê..."
                android:textSize="14sp"
                android:textColor="@color/dashboard_text_secondary"
                android:layout_marginTop="12dp" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
