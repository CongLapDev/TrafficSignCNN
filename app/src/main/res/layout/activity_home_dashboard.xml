<?xml version="1.0" encoding="utf-8"?>
<!--
    HomeDashboardActivity layout
    Design: OLED dark, sapphire blue accent (#3B82F6), premium Material3
    Pattern: Header → Summary card → 2-col feature grid → App info footer
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════
                 HEADER SECTION
            ═══════════════════════════════════════ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Header gradient background -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/dashboard_header_bg" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="52dp"
                    android:paddingBottom="28dp">

                    <!-- Top row: greeting + avatar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Greeting text block -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvGreeting"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Xin chào, Lập"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="@color/dashboard_text_primary"
                                android:letterSpacing="-0.01"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Traffic Sign Recognition"
                                android:textSize="13sp"
                                android:textColor="@color/dashboard_text_secondary"
                                android:layout_marginTop="3dp" />
                        </LinearLayout>

                        <!-- Avatar button (48dp — meets Android touch target) -->
                        <FrameLayout
                            android:id="@+id/btnAvatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/avatar_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless">

                            <TextView
                                android:id="@+id/tvAvatarInitial"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="L"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />
                        </FrameLayout>
                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <!-- ══════════════════════════════════════
                 SUMMARY CARD
            ═══════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="-8dp"
                app:cardBackgroundColor="@color/dashboard_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:strokeColor="@color/dashboard_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Stat: Total scans today -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lượt quét hôm nay"
                                android:textSize="11sp"
                                android:textColor="@color/dashboard_text_muted"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/tvTotalScans"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="@color/dashboard_primary"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="lần"
                                android:textSize="12sp"
                                android:textColor="@color/dashboard_text_secondary" />
                        </LinearLayout>

                        <!-- Divider -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/dashboard_border"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp" />

                        <!-- Stat: Most detected -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.4"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phát hiện nhiều nhất"
                                android:textSize="11sp"
                                android:textColor="@color/dashboard_text_muted"
                                android:textAllCaps="true"
                                android:letterSpacing="0.06" />

                            <TextView
                                android:id="@+id/tvMostDetected"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Giới hạn 60"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/dashboard_text_primary"
                                android:layout_marginTop="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="biển báo"
                                android:textSize="12sp"
                                android:textColor="@color/dashboard_text_secondary" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dashboard_border"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="16dp" />

                    <!-- AI Model Ready chip row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/chip_ai_ready_bg"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <!-- Green dot -->
                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/dot_online" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AI Model Ready"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/dashboard_success"
                                    android:layout_marginStart="7dp" />
                            </LinearLayout>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvModelVersion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="custom_cnn_v1_fp16"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_muted"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════════
                 FEATURE SECTION HEADER
            ═══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tính năng"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/dashboard_text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginStart="24dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp" />

            <!-- ══════════════════════════════════════
                 2-COLUMN FEATURE GRID
            ═══════════════════════════════════════ -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:useDefaultMargins="false">

                <!-- Row 1: Live + Capture -->

                <!-- Feature: Quét Realtime -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureLive"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/feat_live"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/icon_circle_live">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_camera"
                                android:tint="#FFFFFF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quét\nRealtime"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_text_primary"
                            android:layout_marginTop="12dp"
                            android:lineSpacingMultiplier="1.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Camera trực tiếp"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Feature: Chụp ảnh -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureCapture"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/feat_capture"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/icon_circle_capture">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_camera"
                                android:tint="#FFFFFF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chụp Ảnh\nNhận Diện"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_text_primary"
                            android:layout_marginTop="12dp"
                            android:lineSpacingMultiplier="1.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chụp từ camera"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Row 2: Gallery + History -->

                <!-- Feature: Thư viện -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureGallery"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/feat_gallery"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/icon_circle_gallery">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_gallery"
                                android:tint="#FFFFFF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Từ Thư\nViện Ảnh"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_text_primary"
                            android:layout_marginTop="12dp"
                            android:lineSpacingMultiplier="1.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chọn từ bộ nhớ"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Feature: Lịch sử -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/feat_history"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/icon_circle_live">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_history"
                                android:tint="#FFFFFF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lịch Sử\nQuét"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_text_primary"
                            android:layout_marginTop="12dp"
                            android:lineSpacingMultiplier="1.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Các lần nhận diện"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginTop="4dp" />

                        <!-- Coming soon badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sắp ra mắt"
                            android:textSize="10sp"
                            android:textColor="@color/dashboard_amber"
                            android:background="@drawable/chip_ai_ready_bg"
                            android:paddingStart="7dp"
                            android:paddingEnd="7dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Row 3: Stats + Profile -->

                <!-- Feature: Thống kê -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/feat_stats"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/icon_circle_capture">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_stats"
                                android:tint="#FFFFFF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thống\nKê"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_text_primary"
                            android:layout_marginTop="12dp"
                            android:lineSpacingMultiplier="1.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Báo cáo chi tiết"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sắp ra mắt"
                            android:textSize="10sp"
                            android:textColor="@color/dashboard_amber"
                            android:background="@drawable/chip_ai_ready_bg"
                            android:paddingStart="7dp"
                            android:paddingEnd="7dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Feature: Hồ sơ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFeatureProfile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/feat_profile"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    app:strokeColor="@color/dashboard_border"
                    app:strokeWidth="1dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/icon_circle_gallery">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_person"
                                android:tint="#FFFFFF" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hồ Sơ\nCá Nhân"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/dashboard_text_primary"
                            android:layout_marginTop="12dp"
                            android:lineSpacingMultiplier="1.1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tài khoản &amp; cài đặt"
                            android:textSize="11sp"
                            android:textColor="@color/dashboard_text_secondary"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sắp ra mắt"
                            android:textSize="10sp"
                            android:textColor="@color/dashboard_amber"
                            android:background="@drawable/chip_ai_ready_bg"
                            android:paddingStart="7dp"
                            android:paddingEnd="7dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- ══════════════════════════════════════
                 APP INFO FOOTER
            ═══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="28dp"
                android:paddingBottom="32dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:id="@+id/tvAppInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TrafficSign AI  |  Model v1  |  App v1.0"
                    android:textSize="11sp"
                    android:textColor="@color/dashboard_text_muted"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
