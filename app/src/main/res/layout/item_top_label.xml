<?xml version="1.0" encoding="utf-8"?>
<!--
    item_top_label.xml
    Single row in the "Top biển báo" list inside StatisticsActivity.
    Layout: [rank] [label name ........ ] [count]
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Rank number -->
    <TextView
        android:id="@+id/tvRank"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFF59E0B"
        android:gravity="center" />

    <!-- Label name -->
    <TextView
        android:id="@+id/tvLabelName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Giới hạn tốc độ (60km/h)"
        android:textSize="14sp"
        android:textColor="#FFF0F4FF"
        android:layout_marginStart="8dp"
        android:ellipsize="end"
        android:maxLines="1" />

    <!-- Count -->
    <TextView
        android:id="@+id/tvLabelCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="18 lần"
        android:textSize="13sp"
        android:textColor="#FF7B93B8"
        android:layout_marginStart="8dp" />

</LinearLayout>
