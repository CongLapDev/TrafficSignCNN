<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/gallery_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_bg">

    <!-- Header bar -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:paddingTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_close"
            app:backgroundTint="#AA112244"
            app:tint="#FFFFFF"
            app:fabSize="mini" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nhận Diện Từ Thư Viện"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingStart="16dp" />
    </LinearLayout>

    <!-- Image preview area -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imageCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#111C30"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Placeholder when no image selected -->
            <LinearLayout
                android:id="@+id/placeholderView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_gallery"
                    android:alpha="0.35"
                    android:tint="#AABBCC" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chưa chọn ảnh"
                    android:textSize="15sp"
                    android:textColor="#556677"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhấn nút bên dưới để chọn ảnh từ thư viện"
                    android:textSize="12sp"
                    android:textColor="#334455"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />
            </LinearLayout>

            <!-- Selected image -->
            <ImageView
                android:id="@+id/selectedImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:visibility="gone"
                android:padding="8dp" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom section: result + pick button -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Result card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_info"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kết quả nhận diện"
                    android:textSize="11sp"
                    android:textColor="@color/result_sub"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/resultText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/result_text"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/analysingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang phân tích..."
                    android:textSize="14sp"
                    android:textColor="@color/result_sub"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pick image button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPickImage"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Chọn Ảnh Từ Thư Viện"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_blue"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_gallery"
            app:iconGravity="start"
            app:iconPadding="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
