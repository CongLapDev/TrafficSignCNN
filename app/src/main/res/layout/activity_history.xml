<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_history.xml
    Scan history screen.
    Design: OLED dark (#050D1A), sapphire primary (#3B82F6), matching dashboard.
    Structure:
      - Header (back button + title + delete-all button)
      - SearchView
      - RecyclerView (scan list, newest first)
      - Empty state overlay
      - Loading overlay
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dashboard_bg"
    android:fitsSystemWindows="true">

    <!-- ══════════════════ HEADER ══════════════════ -->
    <LinearLayout
        android:id="@+id/historyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/dashboard_surface_2"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <!-- Title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Back FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_close"
                app:backgroundTint="@color/dashboard_surface"
                app:tint="@color/dashboard_text_primary"
                app:fabSize="mini"
                app:elevation="0dp"
                app:borderWidth="0dp"
                android:contentDescription="Quay lại" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lịch Sử Quét"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/dashboard_text_primary"
                android:layout_marginStart="12dp" />

            <!-- Scan count badge -->
            <TextView
                android:id="@+id/tvScanCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 lượt"
                android:textSize="12sp"
                android:textColor="@color/dashboard_primary"
                android:background="@drawable/chip_ai_ready_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="8dp" />

            <!-- Delete all button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xóa tất cả"
                android:textSize="12sp"
                app:backgroundTint="#1A1A2E"
                android:textColor="@color/auth_error"
                app:strokeColor="@color/auth_error"
                app:strokeWidth="1dp"
                app:cornerRadius="20dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Search bar -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/avatar_bg"
            app:queryHint="Tìm theo tên biển báo..."
            app:searchIcon="@drawable/ic_live_scan"
            app:closeIcon="@drawable/ic_close"
            app:queryBackground="@android:color/transparent"
            app:iconifiedByDefault="false" />
    </LinearLayout>

    <!-- ══════════════════ CONTENT ══════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- SwipeRefreshLayout wraps only the RecyclerView -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="8dp"
                android:paddingBottom="24dp"
                android:clipToPadding="false"
                android:scrollbars="none"
                android:overScrollMode="never" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Empty state — shown over SwipeRefreshLayout when list is empty -->
        <LinearLayout
            android:id="@+id/emptyStateView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_history"
                android:tint="@color/dashboard_text_muted"
                android:alpha="0.5"
                android:contentDescription="Trống" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có lịch sử quét"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/dashboard_text_secondary"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bắt đầu quét biển báo để&#10;lịch sử xuất hiện tại đây"
                android:textSize="14sp"
                android:textColor="@color/dashboard_text_muted"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Loading overlay — shown on first load, hidden after data arrives -->
        <FrameLayout
            android:id="@+id/loadingView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80050D1A"
            android:visibility="visible">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/dashboard_primary" />
        </FrameLayout>

    </FrameLayout>

</LinearLayout>
